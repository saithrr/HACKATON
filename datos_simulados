      "source": [
        "- Creamos nuestra base de datos simulada con la historia de 5,000 hogares, apartamentos y comercios pequeños."
      ],
      "metadata": {
        "id": "s0Db2LFNYnIf"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Tarifa de referencia estandarizada por kWh\n",
        "\n",
        "TARIFA_KWH = 0.75\n",
        "\n",
        "# Catálogo de equipos eléctricos (Potencia en Watts)\n",
        "\n",
        "catalogo_equipos = {\n",
        "    'Aire Acondicionado': 1500,\n",
        "    'Nevera': 900,\n",
        "    'Refrigerador': 200,\n",
        "    'Televisor': 120,\n",
        "    'Lavadora': 500,\n",
        "    'Microondas': 1200,\n",
        "    'Foco LED': 15,\n",
        "    'Computadora': 250,\n",
        "    'Plancha': 1000\n",
        "}\n",
        "\n",
        "# Base datos de los hogares\n",
        "\n",
        "datos = pd.DataFrame({\n",
        "    'consumo_kwh': np.random.uniform(50, 800, n_muestras).round(2),\n",
        "    'uso_horario_pico': np.random.choice([True, False], n_muestras, p=[0.6, 0.4]),\n",
        "    'cantidad_equipos': np.random.randint(1, 16, n_muestras),\n",
        "    'tipo_inmueble': np.random.choice([\"Casa\", \"Apartamento\", \"Comercio Pequeño\"], n_muestras),\n",
        "    'horas_alto_consumo': np.random.randint(0, 13, n_muestras)\n",
        "})\n",
        "\n",
        "# Agregamos el cálculo del impacto financiero con la tarifa de 0.75 dólares\n",
        "\n",
        "datos['facturacion_usd'] = (datos['consumo_kwh'] * TARIFA_KWH).round(2)"
      ],
